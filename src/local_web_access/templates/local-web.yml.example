# Local Web Access 默认配置示例
# 由 lwa init 写入工作区根目录。

managerPort: 17800
portPool:
  start: 18000
  end: 19999
staticGateway: caddy          # caddy | nginx | builtin
buildConcurrency: 1
defaultResourceLimits:
  memory: 512m
  cpus: "0.75"
lanIpStrategy: auto           # auto | manual
manualLanIp: null
logLevel: INFO
